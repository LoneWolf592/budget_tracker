generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid())
  name         String
  email        String         @unique
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  transactions Transaction[]
  budgets      Budget[]
  sharedWith   SharedAccess[] @relation("Owner")
  guestAccess  SharedAccess[] @relation("Guest")
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String
  amount    Float
  type      TransactionType
  category  String
  date      DateTime
  notes     String?
  createdAt DateTime        @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  category    String
  limitAmount Float
  month       Int
  year        Int
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category, month, year])
}

model SharedAccess {
  id         String     @id @default(uuid())
  ownerId    String
  guestEmail String
  permission Permission
  createdAt  DateTime   @default(now())

  owner User  @relation("Owner", fields: [ownerId], references: [id], onDelete: Cascade)
  guest User? @relation("Guest", fields: [guestEmail], references: [email])
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum Permission {
  VIEW
  EDIT
}
